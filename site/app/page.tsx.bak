import ProductCarousel from '@/components/ProductCarousel';
import Sidebar from '@/components/Sidebar';
import Footer from '@/components/Footer';
import Link from 'next/link';
import Image from 'next/image';

async function fetchProducts(queryParams: string) {
  try {
    const res = await fetch(
      `${process.env.NEXT_PUBLIC_BASE_URL || 'http://localhost:3000'}/api/products?${queryParams}`,
      { cache: 'no-store' }
    );
    if (!res.ok) return [];
    return res.json();
  } catch {
    return [];
  }
}

function RankBadge({ rank }: { rank: number }) {
  if (rank === 1) return (
    <span className="relative flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-br from-yellow-300 via-yellow-500 to-yellow-700 text-white font-black text-sm italic shadow-[0_0_15px_rgba(234,179,8,0.5)] border border-yellow-200/50">
      <span className="drop-shadow-[0_0_2px_rgba(255,255,255,0.8)]">1</span>
      <span className="material-symbols-outlined absolute -top-1 -right-1 text-[10px] text-white animate-pulse">flare</span>
    </span>
  );
  if (rank === 2) return (
    <span className="relative flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-br from-slate-200 via-slate-400 to-slate-600 text-white font-black text-sm italic shadow-[0_0_15px_rgba(148,163,184,0.5)] border border-slate-100/50">
      <span className="drop-shadow-[0_0_2px_rgba(255,255,255,0.8)]">2</span>
      <span className="material-symbols-outlined absolute -top-1 -right-1 text-[10px] text-white animate-pulse">flare</span>
    </span>
  );
  if (rank === 3) return (
    <span className="relative flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-br from-[#E6B980] via-[#CD7F32] to-[#8B4513] text-white font-black text-sm italic shadow-[0_0_15px_rgba(205,127,50,0.5)] border border-[#E6B980]/50">
      <span className="drop-shadow-[0_0_2px_rgba(255,255,255,0.8)]">3</span>
      <span className="material-symbols-outlined absolute -top-1 -right-1 text-[10px] text-white animate-pulse">flare</span>
    </span>
  );
  return (
    <span className="flex items-center justify-center w-7 h-7 rounded-full bg-slate-200 text-slate-600 font-black text-sm italic">
      {rank}
    </span>
  );
}

function RankingItem({ product, rank }: { product: any; rank: number }) {
  const imgSrc = product.main_image_url
    ? product.main_image_url.replace('pb_e_', 'pf_o1_')
    : product.main_image_url;

  return (
    <div className="flex items-center space-x-4 p-3 bg-gray-50/50 border border-gray-100 rounded-[4px] hover:bg-white hover:shadow-sm transition-all group">
      <div className="flex-shrink-0 w-8 text-center">
        <RankBadge rank={rank} />
      </div>
      {imgSrc ? (
        <div className="relative w-12 h-16 flex-shrink-0">
          <Image
            src={imgSrc}
            alt={product.title}
            fill
            className="object-cover rounded shadow-sm"
            unoptimized
          />
        </div>
      ) : (
        <div className="w-12 h-16 flex-shrink-0 bg-gray-200 rounded" />
      )}
      <div className="flex-1 min-w-0">
        <h4 className="font-bold text-sm text-gray-900 group-hover:underline truncate">{product.title}</h4>
        {product.actresses && (
          <p className="text-[11px] text-gray-500 truncate">{product.actresses}</p>
        )}
        {product.genres && (
          <div className="flex items-center mt-1">
            <span className="text-[9px] bg-white px-1 border border-gray-100 rounded text-gray-500">
              {product.genres.split(',')[0]}
            </span>
          </div>
        )}
      </div>
      <div className="flex-shrink-0">
        <Link
          href={`/product/${product.product_id}`}
          className="text-[10px] text-primary font-bold border border-primary px-2.5 py-1 rounded-[4px] hover:bg-primary hover:text-white transition-colors"
        >
          詳細
        </Link>
      </div>
    </div>
  );
}

export default async function HomePage() {
  const [newProducts, upcomingProducts, topThisYear, topAllTime] = await Promise.all([
    fetchProducts('sort=new&limit=15'),
    fetchProducts('sort=new&fromDate=2026-03-01&limit=15'),
    fetchProducts('sort=wish_count&fromDate=2026-01-01&limit=6'),
    fetchProducts('sort=wish_count&limit=6'),
  ]);

  return (
    <>
    <div className="animate-fade-in">

      {/* ─── ヒーローバナー ─── */}
      <div className="bg-white border-b border-gray-100 py-8 px-4 sm:px-6 lg:px-8">
        <div className="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-8 overflow-hidden relative">
          <div className="flex-1 z-10">
            <p className="text-primary font-black text-xs tracking-widest uppercase mb-4">Premium Concierge</p>
            <h1 className="text-4xl sm:text-5xl font-black tracking-tighter leading-none mb-6 text-gray-900">
              あなたのための<br />
              <span className="text-primary">至極の作品</span>を
            </h1>
            <p className="text-sm text-gray-500 leading-relaxed mb-8 max-w-md">
              11万件を超える作品の中から、あなたの好みに合わせた最高の体験をコンシェルジュが提案します。
            </p>
            <div className="flex gap-4">
              <Link href="/ranking" className="px-6 py-3 bg-primary text-white font-bold rounded-full shadow-lg shadow-primary/20 hover:bg-primary-light transition-all">
                ランキングを見る
              </Link>
              <Link href="/search" className="px-6 py-3 bg-gray-100 text-gray-600 font-bold rounded-full hover:bg-gray-200 transition-all">
                詳細検索
              </Link>
            </div>
          </div>
          <div className="flex-1 opacity-10 absolute right-[-10%] top-[-10%] select-none pointer-events-none">
            <span className="material-symbols-outlined text-[300px]">auto_awesome</span>
          </div>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div className="flex flex-col lg:flex-row gap-8">
          <div className="flex-1 space-y-8">

            {/* 予約・近日発売 */}
            <section className="border-b border-gray-100 pb-8">
              <div className="flex items-center justify-between mb-3 border-b border-gray-100 pb-2">
                <h2 className="text-lg font-bold tracking-tight flex items-center">
                  予約・近日発売
                  <span className="ml-2 text-[10px] font-normal text-gray-400 uppercase tracking-widest">Pre-Order</span>
                </h2>
                <Link href="/search?sort=new" className="text-[10px] font-bold uppercase tracking-wider text-gray-400 hover:text-black transition-colors">
                  もっと見る
                </Link>
              </div>
              <ProductCarousel products={upcomingProducts} aspectRatio="poster" labelBadge="予約" />
            </section>

            {/* 新作 */}
            <section className="border-b border-gray-100 pb-8">
              <div className="flex items-center justify-between mb-3 border-b border-gray-100 pb-2">
                <h2 className="text-lg font-bold tracking-tight flex items-center">
                  新作
                  <span className="ml-2 text-[10px] font-normal text-gray-400 uppercase tracking-widest">New Arrivals</span>
                </h2>
                <Link href="/search?sort=new" className="text-[10px] font-bold uppercase tracking-wider text-gray-400 hover:text-black transition-colors">
                  もっと見る
                </Link>
              </div>
              <ProductCarousel products={newProducts} aspectRatio="poster" labelBadge="新作" />
            </section>

            {/* ランキング */}
            <section>
              <div className="flex items-end justify-between mb-4 border-b border-gray-100 pb-3">
                <h3 className="text-xl font-bold tracking-tight">
                  2026年ランキング
                  <span className="text-xs font-normal text-gray-400 ml-2">2026 Ranking</span>
                </h3>
                <Link href="/ranking" className="text-[10px] font-bold uppercase tracking-wider text-gray-400 hover:text-black transition-colors">
                  すべてのランキング
                </Link>
              </div>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 mb-8">
                {topThisYear.slice(0, 6).map((p: any, i: number) => (
                  <RankingItem key={p.product_id} product={p} rank={i + 1} />
                ))}
              </div>

              <div className="flex items-end justify-between mb-4 border-b border-gray-100 pb-3">
                <h3 className="text-xl font-bold tracking-tight">
                  全期間ランキング
                  <span className="text-xs font-normal text-gray-400 ml-2">All Time</span>
                </h3>
                <Link href="/ranking" className="text-[10px] font-bold uppercase tracking-wider text-gray-400 hover:text-black transition-colors">
                  すべてのランキング
                </Link>
              </div>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3">
                {topAllTime.slice(0, 6).map((p: any, i: number) => (
                  <RankingItem key={p.product_id} product={p} rank={i + 1} />
                ))}
              </div>
            </section>

          </div>

          {/* サイドバー */}
          <Sidebar className="hidden lg:block w-[320px] flex-shrink-0" />
        </div>
      </div>
    </div>
    <Footer />
    </>
  );
}
